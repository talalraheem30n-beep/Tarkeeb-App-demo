# ── Tarkeeb Environment Variables ──
# Copy this file to .env and fill in your real values.
# On Render / Railway / Heroku, set these as Environment Variables in the dashboard.

# ── Session ──
# Generate a strong random string, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# ── Google OAuth ──
# 1. Go to https://console.cloud.google.com/
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
# 3. Add your production URL to Authorized Redirect URIs:
#    https://your-app.onrender.com/auth/google/callback
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# ── Facebook OAuth ──
# 1. Go to https://developers.facebook.com/ → My Apps
# 2. Add your production URL to Valid OAuth Redirect URIs:
#    https://your-app.onrender.com/auth/facebook/callback
FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID_HERE
FACEBOOK_APP_SECRET=YOUR_FACEBOOK_APP_SECRET_HERE

# ── App URL (used for OAuth callbacks in production) ──
# Set this to your deployed URL, e.g.: https://tarkeeb.onrender.com
APP_URL=http://localhost:3000
